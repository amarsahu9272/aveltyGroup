rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    // Collection: projects
    // Document ID: auto-generated
    // Fields:
    //   - title: string (required)
    //   - description: string (required)
    //   - location: string (required)
    //   - type: string (required, enum: Residential, Commercial, Roads, Infrastructure)
    //   - status: string (required, enum: Ongoing, Completed)
    //   - imageUrl: string (optional)
    //   - gallery: list (optional)
    //   - timeline: string (optional)
    //   - createdAt: timestamp (required)
    //   - updatedAt: timestamp (required)
    //   - staffAssigned: list (optional)
    //
    // Collection: leads
    // Document ID: auto-generated
    // Fields:
    //   - name: string (required)
    //   - email: string (required, email format)
    //   - phone: string (required)
    //   - requirement: string (required)
    //   - status: string (required, enum: New, Contacted, Converted, Closed)
    //   - createdAt: timestamp (required)
    //
    // Collection: users
    // Document ID: userId (uid)
    // Fields:
    //   - uid: string (required)
    //   - email: string (required)
    //   - displayName: string (optional)
    //   - role: string (required, enum: admin, staff)
    // ===============================================================

    // Helper Functions
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isAuthenticated() && (
        (request.auth.token.email == "amaratwork01@gmail.com" && request.auth.token.email_verified == true) ||
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
         get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin')
      );
    }

    function isStaff() {
      return isAuthenticated() && (
        isAdmin() ||
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
         get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'staff')
      );
    }

    // Domain Validators
    function isValidProject(data) {
      return data.title is string && data.title.size() > 0 && data.title.size() < 200 &&
             data.description is string && data.description.size() > 0 && data.description.size() < 5000 &&
             data.location is string && data.location.size() > 0 &&
             data.type in ['Residential', 'Commercial', 'Roads', 'Infrastructure'] &&
             data.status in ['Ongoing', 'Completed'] &&
             (!('statusHistory' in data) || data.statusHistory is list);
    }

    function isValidLead(data) {
      return data.name is string && data.name.size() > 0 && data.name.size() < 100 &&
             data.email is string && data.email.size() > 0 &&
             data.phone is string && data.phone.size() > 0 &&
             data.requirement is string && data.requirement.size() > 0 && data.requirement.size() < 2000;
    }

    function isValidUser(data) {
      return data.uid is string && data.email is string &&
             data.role in ['admin', 'staff'];
    }

    function isValidNotification(data) {
      return data.type in ['project_status_change', 'new_lead'] &&
             data.title is string && data.title.size() > 0 && data.title.size() < 200 &&
             data.message is string && data.message.size() > 0 && data.message.size() < 1000 &&
             data.createdAt is timestamp;
    }

    // Rules
    match /projects/{projectId} {
      allow read: if true;
      allow create, update: if isStaff() && isValidProject(request.resource.data);
      allow delete: if isAdmin();
    }

    match /leads/{leadId} {
      allow read: if isStaff();
      allow create: if isValidLead(request.resource.data);
      allow update: if isStaff();
      allow delete: if isAdmin();
    }

    match /users/{userId} {
      allow read: if isAuthenticated() && (isOwner(userId) || isStaff());
      allow create: if isAuthenticated() && isOwner(userId);
      allow update: if isAdmin() || (isOwner(userId) && request.resource.data.role == resource.data.role);
      allow delete: if isAdmin();
    }

    match /notifications/{notificationId} {
      allow read: if isStaff();
      allow create: if isValidNotification(request.resource.data) && (
        (request.resource.data.type == 'new_lead') ||
        (request.resource.data.type == 'project_status_change' && isStaff())
      );
      allow update: if isStaff();
      allow delete: if isAdmin();
    }
  }
}
